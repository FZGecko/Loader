return function(import)
    local Kernel = import("Core/Kernel")
    local Services = import("Core/Services")
    local UserInputService = Services.Get("UserInputService") -- Localized for clarity
    
    -- [ Optimization ] Localize globals
    local pcall, pairs, tostring, type = pcall, pairs, tostring, type
    local IsKeyDown = UserInputService.IsKeyDown
    
    local InputManager = {
        _binds = {} -- Optimized: Keyed by KeyCode/UserInputType for direct lookup
    }
    
    -- Checks if all required modifier keys are currently pressed.
    local function AreModifiersPressed(modifiers)
        if not modifiers then return true end -- No modifiers required
        for _, modKey in pairs(modifiers) do
            if not IsKeyDown(UserInputService, modKey) then
                return false -- A required modifier is not pressed
            end
        end
        return true
    end

    -- [ Master Connection ]
    Kernel:Connect(UserInputService.InputBegan, function(input, gameProcessed)
        if gameProcessed then return end

        -- Use UserInputType for non-keyboard inputs like mouse clicks
        local key = input.KeyCode
        if key == Enum.KeyCode.Unknown then
            key = input.UserInputType
        end

        -- Direct lookup instead of a full loop
        local bindsForKey = InputManager._binds[key]
        if bindsForKey then
            for name, bind in pairs(bindsForKey) do
                if AreModifiersPressed(bind.Modifiers) then
                    local success, err = pcall(bind.Callback)
                    if not success then
                        warn("[InputManager] Error in bind '" .. tostring(name) .. "':", err)
                    end
                end
            end
        end
    end)
    
    -- [ Public API ]
    function InputManager:Bind(name, key, modifiers, callback)
        -- Handle optional 'modifiers' argument
        if type(modifiers) == "function" and callback == nil then
            callback = modifiers
            modifiers = nil
        end

        self._binds[key] = self._binds[key] or {}
        self._binds[key][name] = {
            Modifiers = modifiers,
            Callback = callback
        }
    end
    
    function InputManager:Unbind(name)
        -- This is now less efficient, but unbinding is rare.
        for key, binds in pairs(self._binds) do
            if binds[name] then
                binds[name] = nil
                if next(binds) == nil then
                    self._binds[key] = nil
                end
                return
            end
        end
    end
    
    return InputManager
end
